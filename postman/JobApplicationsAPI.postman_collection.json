              "code": 201,
              "body": "{\n  \"data\": { \"id\": \"uuid\", \"status\": \"pending\" },\n  \"meta\": null,\n  \"error\": null\n}"
            },
            {
              "name": "409 Already Applied",
              "originalRequest": { "method": "POST", "url": { "raw": "{{base_url}}/applications/{{job_id}}/apply" } },
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"data\": null,\n  \"meta\": null,\n  \"error\": { \"code\": \"ALREADY_APPLIED\", \"message\": \"You have already applied for this job.\", \"statusCode\": 409 }\n}"
            }
          ]
        },
        {
          "name": "List My Applications (applicant)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/applications/mine?page=1&limit=10", "host": ["{{base_url}}"], "path": ["applications", "mine"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "10" }] }
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": { "method": "GET", "url": { "raw": "{{base_url}}/applications/mine" } },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": [ { \"id\": \"uuid\", \"status\": \"pending\", \"job\": { \"title\": \"Junior API Developer\" } } ],\n  \"meta\": { \"page\": 1, \"limit\": 10, \"total\": 1, \"totalPages\": 1 },\n  \"error\": null\n}"
            }
          ]
        },
        {
          "name": "List All Applications (recruiter+)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/applications?page=1&limit=10", "host": ["{{base_url}}"], "path": ["applications"], "query": [{ "key": "page", "value": "1" }, { "key": "limit", "value": "10" }] }
          },
          "response": [
            {
              "name": "200 OK",
              "originalRequest": { "method": "GET", "url": { "raw": "{{base_url}}/applications" } },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": [ { \"id\": \"uuid\", \"status\": \"pending\", \"applicant\": { \"fullName\": \"John Applicant\" } } ],\n  \"meta\": { \"page\": 1, \"limit\": 10, \"total\": 1, \"totalPages\": 1 },\n  \"error\": null\n}"
            }
          ]
        },
        {
          "name": "Update Application Status (recruiter+)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"shortlisted\"\n}" },
            "url": { "raw": "{{base_url}}/applications/{{application_id}}/status", "host": ["{{base_url}}"], "path": ["applications", "{{application_id}}", "status"] }
