          "response": [
            {
              "name": "200 OK",
              "originalRequest": { "method": "PATCH", "url": { "raw": "{{base_url}}/applications/{{application_id}}/status" } },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": { \"id\": \"uuid\", \"status\": \"shortlisted\", \"reviewedBy\": { \"fullName\": \"Jane Recruiter\" } },\n  \"meta\": null,\n  \"error\": null\n}"
            }
          ]
        }
      ]
